public class ExampleGraphicIconAddRmvAnmte implements Runnable {

    Map2D map;
    GISCommonFactory commonFactory;
    ArrayList<IGISGraphic> graphicArrayList = new ArrayList<>();
    Map<IGISGraphic, Long> graphicMap = new ConcurrentHashMap<>();
    String[] symbolIdArray = new String[3];
    boolean app6Flag = false;

    public static void main(String[] args) {
        ExampleGraphicIconAddRmvAnmte aMain = new ExampleGraphicIconAddRmvAnmte();
        Thread displayT = new Thread(aMain);
        displayT.start();
    }

    public void run() {
        JFrame mainFrame = new JFrame("HELLO TMAP-J HEAVYWEIGHT");
        commonFactory = new GISCommonFactory();
        mainFrame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        JPanel aPanelTop = new JPanel();
        mainFrame.add(aPanelTop);

        // API entry point
        MapBuilder mapBuilder = commonFactory.createMapBuilder(aPanelTop);
        mapBuilder.displayExampleDted(true)
            .setTargetFPS(12)
            .setBufferType(IGISMap2D.BUFFER_TYPE_LIGHTWEIGHT);
        map = (Map2D) commonFactory.createMap(mapBuilder);
        map.setMaxFpsOnInteraction(false);

        // Sets background color to gray
        map.setBackgroundColor(0.501960813999176, 0.501960813999176, 0.501960813999176, 1.0);
        mainFrame.setSize(1920, 1000);
        mainFrame.setVisible(true);
        SymbolManager.getInstance().addToImageMap("CUSTOM_ICON1", new TmapBufferedImage(ImageUtil.getResourceAsStream("delete.png")));
        SymbolManager.getInstance().addToImageMap("CUSTOM_ICON2", new TmapBufferedImage(ImageUtil.getResourceAsStream("2dMap.png")));

        IGISGraphicIcon graphicIcon = commonFactory.createGraphicIcon();
        graphicIcon.setCustomSymbol(true);
        graphicIcon.setName("test");
        graphicIcon.setSymbolId("CUSTOM_ICON1");
        graphicIcon.setPosition(new GISPosition(36, 37, 0));
        map.add(graphicIcon);

        IGISGraphicIcon graphicIcon1 = commonFactory.createGraphicIcon();
        graphicIcon1.setCustomSymbol(true);
        graphicIcon1.setName("test");
        graphicIcon1.setSymbolId("CUSTOM_ICON1");
        graphicIcon1.setPosition(new GISPosition(36, 37, 0));
        map.add(graphicIcon1);

        IGISGraphicIcon graphicIcon2 = commonFactory.createGraphicIcon();
        graphicIcon2.setCustomSymbol(true);
        graphicIcon2.setName("test");
        graphicIcon2.setSymbolId("CUSTOM_ICON2");
        graphicIcon2.setPosition(new GISPosition(36, 37, 0));
        map.add(graphicIcon2);
//        graphicIcon1.makeAnimation(12000, null, IGISGraphic.ANIMATE_FADE);
//        graphicIcon2.makeAnimation(12000, null, IGISGraphic.ANIMATE_FADE);
//        graphicIcon.makeAnimation(12000, null, IGISGraphic.ANIMATE_FADE);

        map.getOSD().setTestButtonPressListener(new IGISMapOSD.TestButtonPressListener() {
            @Override
            public void onTestButtonPressed() {
                runWithCustomIcon();
            }
        });
    }


    public void runWithCustomIcon() {
        SymbolManager.getInstance().addToImageMap("CUSTOM_ICON1", new TmapBufferedImage(ImageUtil.getResourceAsStream("delete.png")));
        SymbolManager.getInstance().addToImageMap("CUSTOM_ICON2", new TmapBufferedImage(ImageUtil.getResourceAsStream("2dMap.png")));
        SymbolManager.getInstance().addToImageMap("CUSTOM_ICON3", new TmapBufferedImage(ImageUtil.getResourceAsStream("3dMap.png")));
        symbolIdArray[0] = "CUSTOM_ICON1";
        symbolIdArray[1] = "CUSTOM_ICON2";
        symbolIdArray[2] = "CUSTOM_ICON3";
        app6Flag = false;
        runThreads();
    }

    private void runWithAppIcon() {
        symbolIdArray[0] = "App6B:FIG_IMF";
        symbolIdArray[1] = "APP6A:G*C*BWDP";
        symbolIdArray[2] = "App6B:FIG_UCDH_H";
        app6Flag = true;
        runThreads();
    }

    public void runThreads() {
        double screenWidth = ((IGISMap2DState) map.getState()).getPixelWidth();
        double screenHeight = ((IGISMap2DState) map.getState()).getPixelHeight();
        Timer t2 = new Timer();
        t2.scheduleAtFixedRate(new TimerTask() {
            @Override
            public void run() {
                double aLat;
                double aLon;
                for (int i = 0; i < 4000; i++) {
                    Random rand = new Random();
                    int randNum = rand.nextInt(3 - 1) + 1;
                    IGISGraphicIcon graphicIcon = commonFactory.createGraphicIcon();
                    graphicIcon.setCustomSymbol(true);
                    graphicIcon.setName("test" + i);
                    graphicIcon.setSymbolId(symbolIdArray[randNum]);
                    if (app6Flag) {
                        graphicIcon.getApp6Info().setSymbolID(symbolIdArray[randNum]);
                    }
                    graphicIcon.getPointSymbolizer().setAggregatable(true);
                    double[] latlon = map.screenToLatLon(screenWidth * Math.random(),
                        screenHeight * Math.random());

                    aLon = latlon[1];
                    aLat = latlon[0];
                    graphicIcon.setPosition(new GISPosition(aLon, aLat, 0));
                    graphicIcon.setAsScreenGraphic(true, false);
                    map.add(graphicIcon);
                    graphicMap.put(graphicIcon, System.currentTimeMillis());
                    graphicIcon.makeAnimation(12000, null, IGISGraphic.ANIMATE_FADE);
                    try {
                        Thread.sleep(3);
                    } catch (InterruptedException e) {
                        e.printStackTrace();
                    }
                }
            }
        }, 0, 12000);

        Timer t = new Timer();
        t.scheduleAtFixedRate(new TimerTask() {
            @Override
            public void run() {
                for (Map.Entry<IGISGraphic, Long> entry : graphicMap.entrySet()) {
                    if (System.currentTimeMillis() - entry.getValue() >= 12000) {
                        graphicArrayList.add(entry.getKey());
                    }
                }

                for (IGISGraphic graphic : graphicArrayList) {
                    map.remove(graphic);
                    map.getPointsLayer().removeChild(graphic);
                    graphicMap.remove(graphic);
                }
                graphicArrayList.clear();
            }
        }, 0, 1000);
    }
}
