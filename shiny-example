/*************************************************************************************
 * SECURITY CLASSIFICATION  : UNCLASSIFIED
 * PURPOSE                  : 5-radar stress test — maintains ~4500 graphics on screen
 * COMMENTS                 : Each radar thread owns 900 graphics (5 x 900 = 4500)
 **************************************************************************************/

package tr.com.havelsan.tmap.demos;

import tr.com.havelsan.tmap.GISCommonFactory;
import tr.com.havelsan.tmap.MapBuilder;
import tr.com.havelsan.tmap.api.geometry.GISPosition;
import tr.com.havelsan.tmap.api.shape.graphic.IGISGraphic;
import tr.com.havelsan.tmap.api.shape.graphic.IGISGraphicIcon;
import tr.com.havelsan.tmap.api.view.IGISMap2D;
import tr.com.havelsan.tmap.api.view.IGISMap2DState;
import tr.com.havelsan.tmap.api.view.IGISMapOSD;
import tr.com.havelsan.tmap.impl.shape.symbol.SymbolManager;
import tr.com.havelsan.tmap.impl.shape.symbol.TmapBufferedImage;
import tr.com.havelsan.tmap.impl.util.ImageUtil;
import tr.com.havelsan.tmap.impl.view.Map2D;

import javax.swing.*;
import java.util.*;
import java.util.concurrent.ConcurrentLinkedDeque;
import java.util.concurrent.ThreadLocalRandom;
import java.util.concurrent.atomic.AtomicBoolean;


public class ExampleGraphicIconAddRmvAnmte implements Runnable {

    private static final int RADAR_COUNT = 5;
    private static final int GRAPHICS_PER_RADAR = 900;  // 5 x 900 = 4500 total
    private static final long GRAPHIC_TTL_MS = 12_000;   // 12 saniye yaşam süresi
    private static final long ADD_INTERVAL_MS = 3;        // add'ler arası bekleme
    private static final long CLEANUP_INTERVAL_MS = 1_000; // temizlik periyodu

    Map2D map;
    GISCommonFactory commonFactory;
    String[] symbolIdArray = new String[3];
    boolean app6Flag = false;
    private final AtomicBoolean running = new AtomicBoolean(false);

    public static void main(String[] args) {
        ExampleGraphicIconAddRmvAnmte aMain = new ExampleGraphicIconAddRmvAnmte();
        Thread displayT = new Thread(aMain);
        displayT.start();
    }

    public void run() {
        JFrame mainFrame = new JFrame("HELLO TMAP-J HEAVYWEIGHT");
        commonFactory = new GISCommonFactory();
        mainFrame.setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
        JPanel aPanelTop = new JPanel();
        mainFrame.add(aPanelTop);

        MapBuilder mapBuilder = commonFactory.createMapBuilder(aPanelTop);
        mapBuilder.displayExampleDted(true)
            .setTargetFPS(12)
            .setBufferType(IGISMap2D.BUFFER_TYPE_LIGHTWEIGHT);
        map = (Map2D) commonFactory.createMap(mapBuilder);
        map.setMaxFpsOnInteraction(false);
        map.setBackgroundColor(0.501960813999176, 0.501960813999176, 0.501960813999176, 1.0);
        mainFrame.setSize(1920, 1000);
        mainFrame.setVisible(true);

        SymbolManager.getInstance().addToImageMap("CUSTOM_ICON1", new TmapBufferedImage(ImageUtil.getResourceAsStream("delete.png")));
        SymbolManager.getInstance().addToImageMap("CUSTOM_ICON2", new TmapBufferedImage(ImageUtil.getResourceAsStream("2dMap.png")));
        SymbolManager.getInstance().addToImageMap("CUSTOM_ICON3", new TmapBufferedImage(ImageUtil.getResourceAsStream("3dMap.png")));

        map.getOSD().setTestButtonPressListener(new IGISMapOSD.TestButtonPressListener() {
            @Override
            public void onTestButtonPressed() {
                runWithCustomIcon();
            }
        });
    }

    public void runWithCustomIcon() {
        symbolIdArray[0] = "CUSTOM_ICON1";
        symbolIdArray[1] = "CUSTOM_ICON2";
        symbolIdArray[2] = "CUSTOM_ICON3";
        app6Flag = false;
        startRadars();
    }

    /**
     * 5 radar thread'ini başlatır. Her radar kendi 900'lük graphic havuzunu yönetir.
     * Ekranda sürekli ~4500 graphic bulunur.
     *
     * Her radar thread'in yaşam döngüsü:
     *   1) 900 graphic'i peş peşe add eder (aralarında 3ms bekleme — gerçek radar simülasyonu)
     *   2) TTL süresi dolan graphic'leri remove eder
     *   3) Remove edilen kadar yeni graphic add eder → sayı hep 900'de kalır
     */
    private void startRadars() {
        if (running.getAndSet(true)) {
            return; // zaten çalışıyor
        }

        double screenWidth = ((IGISMap2DState) map.getState()).getPixelWidth();
        double screenHeight = ((IGISMap2DState) map.getState()).getPixelHeight();

        for (int radarId = 0; radarId < RADAR_COUNT; radarId++) {
            final int rid = radarId;
            Thread radarThread = new Thread(() -> runRadar(rid, screenWidth, screenHeight),
                "Radar-" + rid);
            radarThread.setDaemon(true);
            radarThread.start();
        }
    }

    /**
     * Tek bir radar thread'i. Kendi graphic listesini yönetir.
     * İlk doldurma (900 adet) sonrası sürekli rotate: expire olanı sil, yerine yenisini koy.
     */
    private void runRadar(int radarId, double screenWidth, double screenHeight) {
        // Her radar'ın kendi graphic havuzu — ekleme sırasına göre (FIFO)
        Deque<GraphicEntry> activeGraphics = new ConcurrentLinkedDeque<>();
        int graphicSeq = 0;

        // --- İlk doldurma: 900 graphic ekle ---
        for (int i = 0; i < GRAPHICS_PER_RADAR; i++) {
            IGISGraphicIcon icon = createIcon(radarId, graphicSeq++, screenWidth, screenHeight);
            map.add(icon);
            activeGraphics.addLast(new GraphicEntry(icon, System.currentTimeMillis()));
            sleep(ADD_INTERVAL_MS);
        }

        // --- Sürekli döngü: expire → remove → add ---
        while (running.get()) {
            int removed = 0;

            // TTL'i dolmuş graphic'leri kuyruğun başından temizle
            while (!activeGraphics.isEmpty()) {
                GraphicEntry oldest = activeGraphics.peekFirst();
                if (oldest != null && System.currentTimeMillis() - oldest.addedAt >= GRAPHIC_TTL_MS) {
                    activeGraphics.pollFirst();
                    map.remove(oldest.graphic);
                    map.getPointsLayer().removeChild(oldest.graphic);
                    removed++;
                } else {
                    break;
                }
            }

            // Remove edilen kadar yenisini ekle → toplam hep 900'de kalır
            for (int i = 0; i < removed; i++) {
                IGISGraphicIcon icon = createIcon(radarId, graphicSeq++, screenWidth, screenHeight);
                map.add(icon);
                activeGraphics.addLast(new GraphicEntry(icon, System.currentTimeMillis()));
                sleep(ADD_INTERVAL_MS);
            }

            // Henüz expire olmamışsa kısa bekle, busy-loop olmasın
            if (removed == 0) {
                sleep(CLEANUP_INTERVAL_MS);
            }
        }
    }

    /**
     * Tek bir graphic icon oluşturur. Pozisyon ekran sınırları içinde rastgele.
     */
    private IGISGraphicIcon createIcon(int radarId, int seq, double screenWidth, double screenHeight) {
        ThreadLocalRandom rand = ThreadLocalRandom.current();

        IGISGraphicIcon icon = commonFactory.createGraphicIcon();
        icon.setCustomSymbol(true);
        icon.setName("radar" + radarId + "_t" + seq);
        icon.setSymbolId(symbolIdArray[rand.nextInt(symbolIdArray.length)]);

        if (app6Flag) {
            icon.getApp6Info().setSymbolID(icon.getSymbolId());
        }

        icon.getPointSymbolizer().setAggregatable(true);

        double[] latlon = map.screenToLatLon(
            screenWidth * rand.nextDouble(),
            screenHeight * rand.nextDouble()
        );
        icon.setPosition(new GISPosition(latlon[1], latlon[0], 0));
        icon.setAsScreenGraphic(true, false);
        icon.makeAnimation(GRAPHIC_TTL_MS, null, IGISGraphic.ANIMATE_FADE);

        return icon;
    }

    private static void sleep(long ms) {
        try {
            Thread.sleep(ms);
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
        }
    }

    /**
     * Graphic + ekleme zamanı çifti. TTL kontrolü için kullanılır.
     */
    private static final class GraphicEntry {
        final IGISGraphic graphic;
        final long addedAt;

        GraphicEntry(IGISGraphic graphic, long addedAt) {
            this.graphic = graphic;
            this.addedAt = addedAt;
        }
    }
}
