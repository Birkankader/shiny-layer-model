    }

    // Faz 3: Dirty-flag cached snapshot
    public ArrayList<IGISGraphic> getControllerGraphics() {
        if (controllerGraphicsDirty) {
            controllerGraphicsSnapshot = new ArrayList<>(controllerGraphicsSet);
            controllerGraphicsDirty = false;
        }
        return controllerGraphicsSnapshot;
    }

    // Faz 3: Dirty-flag cached snapshot
    public ArrayList<IGISGraphic> getScreenGraphics() {
        if (screenGraphicsDirty) {
            screenGraphicsSnapshot = new ArrayList<>(screenGraphicsSet);
            screenGraphicsDirty = false;
        }
        return screenGraphicsSnapshot;
    }

