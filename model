    public LayerModel() {
    }

    private static final Logger LOGGER = LogManager.getLogger(LayerModel.class);

    private void processWaitingGraphicEvents(AGISGL gl) {
        ArrayList<IGISGraphic> cloneGraphics = new ArrayList<>(waitingGraphicEvents);
        waitingGraphicEvents.clear();
        while (!cloneGraphics.isEmpty()) {
            IGISGraphic graphic = cloneGraphics.get(0);
            if (graphic == null) {
                cloneGraphics.remove(0);
                return;
            }

            try {
                if (graphic.getClientProperty("Event") == null) {
                    graphic.putClientProperty("Event", 1);
                }
                if ((Integer) graphic.getClientProperty("Event") == 0) {
                    addGraphic(graphic);
                } else if ((Integer) graphic.getClientProperty("Event") == 1) {
                    removeGraphic(graphic, gl);
                } else if ((Integer) graphic.getClientProperty("Event") == 2) {
                    removeControllerGraphicProcess(graphic, gl);
                } else if ((Integer) graphic.getClientProperty("Event") == 3) {
                    addControllerGraphicProcess(graphic);
                }
                cloneGraphics.remove(0);
            } catch (Exception e) {
                LOGGER.error(e.getMessage());
            }
        }
    }


    private void addGraphic(IGISGraphic graphic) {
        try {
            if (graphic.isScreenGraphic() && !screenGraphics.contains(graphic)) {
                screenGraphics.add(graphic);
            } else if (graphic instanceof IGISGraphicIcon) {
                pointAggGraphic.addChild(graphic);
            } else {
                if (!(graphic instanceof IGISLayer && ((IGISLayer) graphic).getRefreshRate() > 0)) {
                    getDrawingLayer().addChild(graphic);
                }
            }
        } catch (Exception e) {
            LOGGER.error(e.getMessage());
        }
    }

    private void removeGraphic(IGISGraphic graphic, AGISGL gl) {
        try {
            if (graphic != null) {
                ((AGraphic) graphic).deleteResources(gl);
            }
        } catch (Exception e) {
            LOGGER.error(e.getMessage());
        }
    }

    private void removeControllerGraphicProcess(IGISGraphic graphic, AGISGL gl) {
        try {
            if (graphic != null) {
                ((AGraphic) graphic).deleteResources(gl);
                if (graphic.isScreenGraphic()) {
                    screenGraphics.remove(graphic);
                } else {
                    controllerGraphics.remove(graphic);
                    controllerGraphicsLayer.removeChild(graphic);
                }
            }
        } catch (Exception e) {
            LOGGER.error(e.getMessage());
        }
    }

    private void addControllerGraphicProcess(IGISGraphic graphic) {
        if (graphic.isScreenGraphic() && !screenGraphics.contains(graphic)) {
            screenGraphics.add(graphic);
        } else {
            controllerGraphics.add(graphic);
            controllerGraphicsLayer.addChild(graphic);
        }
    }

    public IGISGraphic add(IGISGraphic graphic) {
        if (null == graphic) {
            return null;
        }
        boolean contains = false;
        graphic.putClientProperty("Event", 0);
        for (int i = 0; i < waitingGraphicEvents.size(); i++) {
            try {
                if (waitingGraphicEvents.get(i) != null && waitingGraphicEvents.get(i).getName().equals(graphic.getName())) {
                    contains = true;
                }
            } catch (Exception e) {
                LOGGER.error(e.getMessage());
            }
        }
        if (!contains) {
            waitingGraphicEvents.add(graphic);
        }
        return graphic;
    }

    public IGISGraphic addControllerGraphic(IGISGraphic graphic) {
        if (null == graphic) {
            return null;
        }
        graphic.putClientProperty("Event", 3);
        if (waitingGraphicEvents.contains(graphic)) {
            return graphic;
        }
        waitingGraphicEvents.add(graphic);
        return graphic;
    }

    public void remove(IGISGraphic graphic) {
        if (graphic == cartographyAggGraphic) {
            return;
        }
        if (null == graphic) {
            return;
        }

        graphic.putClientProperty("Event", 1);
        waitingGraphicEvents.add(graphic);
        List<IGISGraphic> boundGraphics = graphic.getBoundGraphics();
        if (null != boundGraphics) {
            graphic.unbindAllGraphics();
            for (IGISGraphic boundGraphic : boundGraphics) {
                for (int i = 0; i < waitingGraphicEvents.size(); i++) {
                    try {
                        if (waitingGraphicEvents.get(i).getName().toLowerCase().equals(boundGraphic.getName())) {
                            waitingGraphicEvents.add(boundGraphic);
                        }
                    } catch (Exception ignored) {

                    }
                }
            }
        }
    }

    public void removeControllerGraphic(IGISGraphic graphic) {
        if (null == graphic) {
            return;
        }
        graphic.putClientProperty("Event", 2);
        if (waitingGraphicEvents.contains(graphic)) {
            return;
        }
        waitingGraphicEvents.add(graphic);
    }

